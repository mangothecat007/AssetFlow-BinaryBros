<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <group
        android:translateX="20"
        android:translateY="20"
        android:scaleX="0.8"
        android:scaleY="0.8">
        <!-- Outer Shield -->
        <path
            android:pathData="M100 20 L170 45 L170 100 C170 145 140 180 100 195 C60 180 30 145 30 100 L30 45 Z"
            android:strokeWidth="12"
            android:strokeLineJoin="round">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:startX="30"
                    android:startY="20"
                    android:endX="170"
                    android:endY="195"
                    android:type="linear">
                    <item android:offset="0" android:color="#FF46C5A5"/>
                    <item android:offset="1" android:color="#FF2A7763"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- Inner Dynamic Ring -->
        <path
            android:pathData="M100,100m-45,0a45,45 0,1 1,90 0a45,45 0,1 1,-90 0"
            android:strokeWidth="8"
            android:strokeAlpha="0.4">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:startX="55"
                    android:startY="55"
                    android:endX="145"
                    android:endY="145"
                    android:type="linear">
                    <item android:offset="0" android:color="#FF46C5A5"/>
                    <item android:offset="1" android:color="#FF2A7763"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- The "1" / Alert Mark center -->
        <path
            android:pathData="M92 55 L114 55 L108 120 L92 120 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="92"
                    android:startY="55"
                    android:endX="114"
                    android:endY="120"
                    android:type="linear">
                    <item android:offset="0" android:color="#FFEF4444"/>
                    <item android:offset="1" android:color="#FF991B1B"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- The "1" dot -->
        <path
            android:pathData="M100,142m-10,0a10,10 0,1 1,20 0a10,10 0,1 1,-20 0">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="90"
                    android:startY="132"
                    android:endX="110"
                    android:endY="152"
                    android:type="linear">
                    <item android:offset="0" android:color="#FFEF4444"/>
                    <item android:offset="1" android:color="#FF991B1B"/>
                </gradient>
            </aapt:attr>
        </path>
    </group>
</vector>
